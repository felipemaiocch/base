{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**/*",
      "use": "@vercel/static"
    }
  ],
  "cleanUrls": true,
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "^/$",
      "dest": "/public"
    },
    {
      "src": "^/admin$",
      "dest": "/public/admin"
    },
    {
      "src": "^/admin/login$",
      "dest": "/public/admin/login"
    },
    {
      "src": "^/api/(.*)$",
      "dest": "/api/$1.js"
    }
  ]
}
